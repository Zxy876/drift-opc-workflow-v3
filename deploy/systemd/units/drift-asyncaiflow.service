[Unit]
Description=Drift AsyncAIFlow Runtime - 7x24
After=network-online.target
Wants=network-online.target
PartOf=drift-stack.target

[Service]
Type=simple
User=__STACK_USER__
EnvironmentFile=/etc/drift-stack.env
WorkingDirectory=/opt/drift-stack-systemd
ExecStart=/opt/drift-stack-systemd/bin/run-asyncaiflow-runtime.sh
Restart=always
RestartSec=5
StartLimitBurst=10
StartLimitIntervalSec=300

[Install]
WantedBy=multi-user.target
WantedBy=drift-stack.target